VITE_LIFF_ID=YOUR_LIFF_ID_HERE

# 本番でメニューを全端末で共有するには、注文APIと同じ KV（KV_REST_*）または REDIS_URL が必要です（未設定時は GET /api/menu が初期メニューを返すのみで、PUT は失敗します）。

# シェア用 OGP の絶対URL（本番ドメイン）。未設定時はビルドで mdy.kranz.design、開発時は localhost。
# VITE_SITE_ORIGIN=https://example.com

# 公式SNS（未設定時は OHACO デフォルト）
# VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/ohaco.yokohama/
# VITE_SOCIAL_LINE=https://lin.ee/pCczHKV
# VITE_SOCIAL_TIKTOK=
# VITE_SOCIAL_THREADS=

# 注文通知メール（Resend）
# RESEND_API_KEY=re_xxx
# ORDER_NOTIFY_TO=owner@example.com
# ORDER_NOTIFY_FROM=onboarding@resend.dev

# 注文プッシュ通知（Pushover）
# PUSHOVER_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PUSHOVER_USER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PUSHOVER_OPEN_URL=https://mdy.kranz.design/admin

# 注文LINE通知（Messaging API）
# LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LINE_NOTIFY_TO=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LINE_NOTIFY_ADMIN_URL=https://mdy.kranz.design/admin
